# KODDEVZ Environment Configuration

# --- Frontend Settings ---
VITE_API_URL=http://localhost:8001/api

# --- Backend (server/.env) ---
# WARNING: The Gemini API Key must remain server-side.
# Never inject this into vite.config.ts or public spaces.
GEMINI_API_KEY=your_gemini_api_key_here
PORT=8001
NODE_ENV=development
APP_URL=http://localhost:3000
